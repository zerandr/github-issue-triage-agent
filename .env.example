# GitHub API access.
# Optional for public repos, but recommended to avoid strict unauthenticated rate limits.
GITHUB_TOKEN=

# Agent model settings.
MODEL_PROVIDER=openai
MODEL_NAME=gpt-5-mini

# Optional API keys depending on selected provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# MCP settings.
USE_MCP=1
MCP_SERVER_COMMAND=python
MCP_SERVER_ARGS=-m src.mcp_custom.server

# Local cache.
TRIAGE_CACHE_PATH=.cache/triage_cache.sqlite

# Agent safety/cost controls.
MAX_STEPS=20
MAX_TOOL_CALLS=12
MAX_LATENCY_SECONDS=60
MAX_TOKENS=8000

# Evaluation output paths.
EVAL_TASKS_PATH=data/eval_tasks.jsonl
TRAJECTORY_DIR=runs/trajectories
EVAL_SUMMARY_PATH=reports/eval_summary.json
